# Copy to ~/.hermes/profiles/<name>/.env and fill in.
# NEVER commit real tokens.

# Required: separate Telegram bot from your main Hermes bot
TELEGRAM_BOT_TOKEN=
# Your Telegram user id and/or @username (comma-separated)
TELEGRAM_ALLOWED_USERS=
# Optional home DM chat id
TELEGRAM_HOME_CHANNEL=

# Model auth is usually cloned from default profile (OAuth in auth.json).
# Or set API keys:
# OPENROUTER_API_KEY=
# XAI_API_KEY=
